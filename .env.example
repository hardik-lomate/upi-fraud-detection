# Security
JWT_SECRET_KEY=your-secret-here-min-32-chars
API_KEYS_FILE=api_keys.json
# Keep authentication enabled in all non-local environments.
# Set AUTH_REQUIRED=false ONLY for local development/testing.
AUTH_REQUIRED=true

# Database
DATABASE_URL=sqlite:///./fraud_detection.db

# CORS
CORS_ORIGINS=http://localhost:3000,https://your-frontend.up.railway.app
# Optional single frontend URL used when CORS_ORIGINS is not set
FRONTEND_URL=

# Redis (optional — falls back to in-memory if unavailable)
REDIS_URL=redis://localhost:6379/0

# Anthropic (optional — for LLM fraud narratives)
ANTHROPIC_API_KEY=

# Script/API testing helper
UPI_API_BASE_URL=https://your-backend.up.railway.app
